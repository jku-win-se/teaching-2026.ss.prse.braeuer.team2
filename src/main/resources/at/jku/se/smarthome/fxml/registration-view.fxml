<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="at.jku.se.smarthome.controller.RegistrationController"
            prefWidth="900"
            prefHeight="600"
            style="-fx-background-color: linear-gradient(to bottom right, #f7f5f2, #ebe4db);">
    <center>
        <VBox alignment="CENTER"
              spacing="16"
              maxWidth="360"
              style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 36;">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24" />
            </padding>
            <children>
                <Label text="Create account"
                       style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2b2b2b;" />
                <Label text="Register with your email address and password."
                       wrapText="true"
                       style="-fx-text-fill: #6e6257;" />
                <TextField fx:id="emailField"
                           promptText="E-Mail"
                           maxWidth="320"
                           style="-fx-background-radius: 10; -fx-padding: 12;" />
                <PasswordField fx:id="passwordField"
                               promptText="Passwort"
                               maxWidth="320"
                               style="-fx-background-radius: 10; -fx-padding: 12;" />
                <Button text="Register"
                        onAction="#handleRegister"
                        maxWidth="320"
                        style="-fx-background-color: #e8752e; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 12 18 12 18;" />
                <Label fx:id="feedbackLabel"
                       wrapText="true"
                       maxWidth="320"
                       style="-fx-text-fill: #6e6257;" />
            </children>
        </VBox>
    </center>
</BorderPane>
