<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="at.jku.se.smarthome.controller.LoginController"
            prefWidth="900"
            prefHeight="600"
            style="-fx-background-color: linear-gradient(to bottom right, #f7f5f2, #ebe4db);">
    <center>
        <VBox alignment="CENTER"
              spacing="16"
              maxWidth="360"
              style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 36;">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24" />
            </padding>
            <children>
                <Label text="Login"
                       style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2b2b2b;" />
                <Label text="Sign in with your registered email address and password."
                       wrapText="true"
                       style="-fx-text-fill: #6e6257;" />

                <VBox fx:id="loginPane" alignment="CENTER" spacing="12">
                    <children>
                        <TextField fx:id="emailField"
                                   promptText="E-Mail"
                                   maxWidth="320"
                                   style="-fx-background-radius: 10; -fx-padding: 12;" />
                        <PasswordField fx:id="passwordField"
                                       promptText="Passwort"
                                       maxWidth="320"
                                       style="-fx-background-radius: 10; -fx-padding: 12;" />
                        <Button text="Login"
                                onAction="#handleLogin"
                                maxWidth="320"
                                style="-fx-background-color: #e8752e; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 12 18 12 18;" />
                    </children>
                </VBox>

                <VBox fx:id="loggedInPane" alignment="CENTER" spacing="12" visible="false" managed="false">
                    <children>
                        <Label fx:id="sessionLabel"
                               wrapText="true"
                               maxWidth="320"
                               style="-fx-text-fill: #2b2b2b; -fx-font-size: 16;" />
                        <Button text="Logout"
                                onAction="#handleLogout"
                                maxWidth="320"
                                style="-fx-background-color: #6e6257; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 12 18 12 18;" />
                    </children>
                </VBox>

                <Label fx:id="feedbackLabel"
                       wrapText="true"
                       maxWidth="320"
                       style="-fx-text-fill: #6e6257;" />
            </children>
        </VBox>
    </center>
</BorderPane>
